{
  "name": "editsy",
  "version": "0.0.11",
  "description": "The little CMS that lives in your repo: edit typed TypeScript content files in the browser",
  "keywords": [
    "cms",
    "content",
    "typescript",
    "nextjs",
    "react",
    "git-based"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18.18"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./markdown": "./src/markdown.ts",
    "./react": "./src/react.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./markdown": {
        "types": "./dist/markdown.d.ts",
        "import": "./dist/markdown.js",
        "require": "./dist/markdown.cjs"
      },
      "./react": {
        "types": "./dist/react.d.ts",
        "import": "./dist/react.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/editsy/editsy.git",
    "directory": "packages/editsy"
  },
  "homepage": "https://editsy.dev",
  "bugs": "https://github.com/editsy/editsy/issues",
  "scripts": {
    "build": "tsup src/index.ts src/markdown.ts --format esm,cjs --dts -d dist --clean && tsup src/react.ts --format esm --dts -d dist",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "react": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}
