{
  "name": "@editsy/next",
  "version": "0.0.11",
  "description": "Serve the editsy content editor from your deployed Next.js site: editors log in, edit, and publish as git commits",
  "keywords": [
    "cms",
    "content",
    "typescript",
    "nextjs",
    "git-based"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "next": ">=13.4"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/editsy/editsy.git",
    "directory": "packages/next"
  },
  "homepage": "https://editsy.dev",
  "bugs": "https://github.com/editsy/editsy/issues",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts -d dist --clean",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@editsy/cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}
